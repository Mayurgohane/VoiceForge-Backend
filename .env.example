# Application
APP_NAME=VoiceForge
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Security
API_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Persistence
DATABASE_URL=sqlite+aiosqlite:///./voiceforge.db
# DATABASE_URL=postgresql+asyncpg://voiceforge:voiceforge@localhost:5432/voiceforge
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600
AUTO_MIGRATE=true
DB_CREATE_ALL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_HEALTH_RETRIES=2

# Voice providers: mock | deepgram | google
STT_PROVIDER=deepgram
# TTS: mock | google | elevenlabs
TTS_PROVIDER=mock
LLM_PROVIDER=mock

# Gemini / Google
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Deepgram Live STT (required for Twilio Media Streams)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_ENDPOINTING_MS=300

# Latency / conversation controls
MAX_TURN_LATENCY_MS=1500
BARGE_IN_ENABLED=true
HANDOFF_CONFIDENCE_THRESHOLD=0.35
ENABLE_PII_REDACTION=true
MAX_USER_TEXT_CHARS=4000
SILENCE_TIMEOUT_SECONDS=45
AUTH_BYPASS=false
REQUIRE_METRICS_AUTH=true
STREAM_TOKEN_TTL_SECONDS=900

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_ENABLED=true

# Twilio Voice + Media Streams
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_AGENT_NUMBER=
TWILIO_GREETING=Hi, you are connected to VoiceForge. How can I help you today?
PUBLIC_BASE_URL=https://YOUR_SUBDOMAIN.ngrok-free.app
STREAM_TOKEN_TTL_SECONDS=900
WARM_TRANSFER_ENABLED=false
WARM_TRANSFER_AGENT_TIMEOUT_SECONDS=30

# Tool authz / rate limits
TOOL_AUTHZ_ENABLED=true
TOOL_STRICT_CALLER_BIND=true
TOOL_RATE_LIMIT_PER_MINUTE=20
